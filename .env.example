# Copy this file to .env and adjust values as needed.
# All defaults below match the docker-compose.yml defaults — the app runs
# without a .env file, so only create one when you need to override something.

# Kafka / Redpanda topics
KAFKA_TOPIC_LOGS=otel-logs
KAFKA_TOPIC_METRICS=otel-metrics
KAFKA_TOPIC_TRACES=otel-traces
KAFKA_PARTITIONS=4
KAFKA_RETENTION_MS=900000
KAFKA_RETENTION_BYTES=1073741824

# Ingester
INGESTER_REPLICAS=1

# ClickHouse
CLICKHOUSE_DSN=clickhouse://clickhouse:9000/default

# Internal service URLs
API_BASE_URL=http://backend-api:8080

# Grafana — change this before exposing Grafana to a network
GRAFANA_PASSWORD=admin
