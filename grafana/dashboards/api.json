{
  "uid": "api",
  "title": "API",
  "schemaVersion": 36,
  "version": 1,
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "15s",
  "links": [
    {
      "title": "Gateway",
      "type": "link",
      "url": "/d/gateway",
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    },
    {
      "title": "Ingester",
      "type": "link",
      "url": "/d/ingester",
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by path",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(http_requests_total[1m])", "legendFormat": "{{method}} {{path}}"}
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(http_requests_total{status=~\"5..\"}[1m])", "legendFormat": "{{method}} {{path}}"}
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 latency by path",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[1m]))", "legendFormat": "{{method}} {{path}}"}
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "In-flight requests",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "http_requests_in_flight", "legendFormat": "{{method}} {{path}}"}
      ]
    }
  ]
}
