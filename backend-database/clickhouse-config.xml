<clickhouse>
    <max_server_memory_usage_to_ram_ratio>0.8</max_server_memory_usage_to_ram_ratio>
    <max_concurrent_queries>500</max_concurrent_queries>
    <max_insert_threads>8</max_insert_threads>
    <background_pool_size>16</background_pool_size>
    <background_merge_mutation_processing_pool_size>8</background_merge_mutation_processing_pool_size>

    <profiles>
        <default>
            <async_insert>1</async_insert>
            <wait_for_async_insert>0</wait_for_async_insert>
            <async_insert_max_data_size>10485760</async_insert_max_data_size>
            <async_insert_busy_timeout_ms>200</async_insert_busy_timeout_ms>
            <log_queries>0</log_queries>
        </default>
    </profiles>
</clickhouse>
